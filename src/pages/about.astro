---
const title: string = "About Me";

const identity = {
  firstName: "Sarah",
  country: "Canada",
  occupation: "Technical Writer",
  hobbies: ["photography", "birdwatching", "baseball"],
};

const skills = ["HTML", "CSS", "Javascript", "React", "Astro", "Writing Docs"];

const happy: boolean = true;
const finished: boolean = false;
const goal: number = 3;

const colorPink: string = "#f32589";
const fontMedium: number = 600;
const textUpper: string = "uppercase";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <ul>
      <li><a href="/astro-tutorial/">Home</a></li>
      <li><a href="/astro-tutorial/about/">About</a></li>
      <li><a href="/astro-tutorial/blog/">Blog</a></li>
    </ul>
    <h1>{title}</h1>

    <p>Here are a few facts about me:</p>
    <ul>
      <li>My name is {identity.firstName}</li>
      <li>I live in {identity.country} and I work as {identity.occupation}.</li>
      {
        identity.hobbies.length >= 2 && (
          <li>
            Two of my hobbies are: {identity.hobbies[0]} and{" "}
            {identity.hobbies[1]}.
          </li>
        )
      }
    </ul>
    <p>My skills are:</p>
    <ul class="skills_list">
      {skills.map((skill) => <li class="skill">{skill}</li>)}
    </ul>

    {happy && <p>I am happy to be learning Astro!</p>}
    {finished && <p>I finished the tutorial</p>}
    {
      goal === 3 ? (
        <p>My goal is to finish in 3 days.</p>
      ) : (
        <p>My goal is not 3 days</p>
      )
    }
  </body>
  <style define:vars={{ colorPink, fontMedium, textUpper }}>
    h1 {
      color: rgb(156, 0, 100);
      font-size: 3em;
    }

    .skill {
      color: var(--colorPink);
      list-style-type: none;
      font-weight: var(--fontMedium);
      text-transform: var(--textUpper);
    }

    .skills_list {
      display: flex;
      gap: 8px;
    }
  </style>
</html>
