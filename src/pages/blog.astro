---
import "../assets/styles/global.css";
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle: string = "Blog";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/astro-tutorial/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <BaseLayout pageTitle={pageTitle}>
      <p>This is the blog page! welcome.</p>
      <ul>
        <li><a href="/astro-tutorial/posts/post-1">Post 1</a></li>
        <li><a href="/astro-tutorial/posts/post-2">Post 2</a></li>
        <li><a href="/astro-tutorial/posts/post-3">Post 3</a></li>
      </ul>
    </BaseLayout>
  </body>
</html>
