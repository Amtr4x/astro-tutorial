---
import "../assets/styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const title: string = "Blog";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/astro-tutorial/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <h1>{title}</h1>
    <p>This is the blog page! welcome.</p>
    <ul>
      <li><a href="/astro-tutorial/posts/post-1">Post 1</a></li>
      <li><a href="/astro-tutorial/posts/post-2">Post 2</a></li>
      <li><a href="/astro-tutorial/posts/post-3">Post 3</a></li>
    </ul>
    <Footer />
  </body>
</html>
